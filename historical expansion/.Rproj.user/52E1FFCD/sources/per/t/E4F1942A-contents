# d) Top code household debt and income variables, replacing all values greater than three ----
# standard deviations above the mean with a value that is equal to three standard deviations 
# above the mean.
# e) Label the new top-coded variables.-----


endline_clean <- endline_clean %>%
  mutate(
    hhinc_top = ifelse(hhinc > mean(hhinc, na.rm = TRUE) + 3 * sd(hhinc, na.rm = TRUE),
                       mean(hhinc, na.rm = TRUE) + 3 * sd(hhinc, na.rm = TRUE),
                       hhinc),
    
    totformalborrow_24_top = ifelse(totformalborrow_24 > mean(totformalborrow_24, na.rm = TRUE) + 3 * sd(totformalborrow_24, na.rm = TRUE),
                                    mean(totformalborrow_24, na.rm = TRUE) + 3 * sd(totformalborrow_24, na.rm = TRUE),
                                    totformalborrow_24),
    
    totinformalborrow_24_top = ifelse(totinformalborrow_24 > mean(totinformalborrow_24, na.rm = TRUE) + 3 * sd(totinformalborrow_24, na.rm = TRUE),
                                      mean(totinformalborrow_24, na.rm = TRUE) + 3 * sd(totinformalborrow_24, na.rm = TRUE),
                                      totinformalborrow_24)
  ) %>%
  set_variable_labels(
    hhinc_top = "Household income (top-coded at 3 SDs above mean)",
    totformalborrow_24_top = "Formal borrowing (top-coded at 3 SDs above mean)",
    totinformalborrow_24_top = "Informal borrowing (top-coded at 3 SDs above mean)"
  )



# g) Create a total borrowed amount variable that equals the sum of formal and informal borrowed amounts----

endline_clean <- endline_clean %>%
  mutate(
    total_borrowed = totformalborrow_24 + totinformalborrow_24
  )


# h) Merge the endline data with the treatment_status dataset to assign a treatment status for ----
# each household.


treatment <- read.csv(here("data", "treatment_status.csv"))

endline_clean <- left_join(endline_clean, treatment, by = c("group_id"))

# i) Create a dummy variable for households that are below the poverty line using a daily per ----
# capita poverty line of 26.995 INR (which was equivalent to 1.90 USD at the time of data collection).
# Use the endline top coded “hhinc” variable, which contains self-reported 
# household income over the past 30 days, in order to do this.


endline_clean <- endline_clean%>%
  mutate(
    daily_per_capita_income = hhinc_top / 30 /hhnomembers,
    below_poverty_line = ifelse(daily_per_capita_income < 26.995, 1, 0)
  )




#   k) Merge working data with the baseline controls dataset, and save the merged data. ----


baseline <- read_dta(here("data", "baseline_controls.dta"))


# Check duplicates in hhids within each dataset
dups_endline <- endline_clean %>% filter(duplicated(hhid) | duplicated(hhid, fromLast = TRUE))
dups_baseline <- baseline %>% filter(duplicated(hhid) | duplicated(hhid, fromLast = TRUE))
#no duplicates

# Households only in endline
only_in_endline <- anti_join(endline_clean, baseline, by = c("hhid", "group_id"))

# Households only in baseline
only_in_baseline <- anti_join(baseline, endline_clean, by = c("hhid", "group_id"))



#Since there are households only in baseline or endline, for analysis purposes, only households found
#both on baseline and endline and have the same group_id are included
#In addition there are households where the income and borrowing data(both formal and informal) is NA
#These households along with their pair are excluded in the dataset


merged_clean <- left_join(endline_clean, baseline, by = c("hhid" = "hhid",
                                                          "group_id" = "group_id")) %>% 
  filter(!is.na(age_hoh)) %>%  
  rename(
    hhnomembers_endline = hhnomembers.x,
    hhnomembers_baseline = hhnomembers.y
  )

