#a) Load the endline data----

endline <- read_dta(here("data", "endline.dta"))

#b) Recode household debt and income variables as ----
#numeric values instead of strings, and replace “None” with 0
#Also mutated "." which means NA in STATA to NA in R

endline_clean <- endline %>%
  mutate(
    across(
      c(totformalborrow_24, totinformalborrow_24, hhinc),
      ~ as.numeric(ifelse(. == "None", 0, ifelse(. == ".", NA, .))) #There are 4 NAs in the borrowing data
    )
  ) %>% 
  filter(
    !is.na(totformalborrow_24) &
      !is.na(totinformalborrow_24) &
      !is.na(hhinc)
  ) #removed the hh with NAs from the dataset for cleaness



# Check duplicates in hh_id
hhid_duplicates <- endline_clean %>%
  filter(duplicated(hhid) | duplicated(hhid, fromLast = TRUE))

#There are no duplicates in the endline data

#c)Browse the variables in this dataset ----


endline_summary <- endline_clean %>%
  summarise(
    hhinc_mean = mean(hhinc, na.rm = TRUE),
    hhinc_median = median(hhinc, na.rm = TRUE),
    hhinc_sd = sd(hhinc, na.rm = TRUE),
    hhinc_min = min(hhinc, na.rm = TRUE),
    hhinc_max = max(hhinc, na.rm = TRUE),
    hhinc_pctzero = mean(hhinc == 0, na.rm = TRUE) * 100,
    
    formalborrow_mean = mean(totformalborrow_24, na.rm = TRUE),
    formalborrow_median = median(totformalborrow_24, na.rm = TRUE),
    formalborrow_sd = sd(totformalborrow_24, na.rm = TRUE),
    formalborrow_min = min(totformalborrow_24, na.rm = TRUE),
    formalborrow_max = max(totformalborrow_24, na.rm = TRUE),
    formalborrow_pctzero = mean(totformalborrow_24 == 0, na.rm = TRUE) * 100,
    
    informalborrow_mean = mean(totinformalborrow_24, na.rm = TRUE),
    informalborrow_median = median(totinformalborrow_24, na.rm = TRUE),
    informalborrow_sd = sd(totinformalborrow_24, na.rm = TRUE),
    informalborrow_min = min(totinformalborrow_24, na.rm = TRUE),
    informalborrow_max = max(totinformalborrow_24, na.rm = TRUE),
    informalborrow_pctzero = mean(totinformalborrow_24 == 0, na.rm = TRUE) * 100
  ) %>%
  pivot_longer(
    cols = everything(),
    names_to = c("Variable", ".value"),
    names_sep = "_"
  ) %>%
  mutate(
    pctzero = sprintf("%.2f%%", pctzero)  # Format to 2 decimals + % sign
  ) %>%
  select(Variable, mean, median, sd, min, max, pctzero)

###endline summary----
