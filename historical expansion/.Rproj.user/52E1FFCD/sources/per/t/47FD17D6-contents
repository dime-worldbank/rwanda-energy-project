)

# e) Re-run the previous regression including a set of household-level controls.----

reg_income_controls <- felm(
  hhinc ~ treated + hhnomembers_baseline + gender_hoh + age_hoh + 
    educyears_hoh + readwrite_hoh + hhcaste_sc_st |
    pair_id | 0 | group_id,
  data = merged_clean
)

summary(reg_income_controls)


reg_log_income_controls <- felm(
  log_hhinc ~ treated + hhnomembers_baseline + gender_hoh + age_hoh + 
    educyears_hoh + readwrite_hoh + hhcaste_sc_st |
    pair_id | 0 | group_id,
  data = merged_clean
)

summary(reg_log_income_controls)


