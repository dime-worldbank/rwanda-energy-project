# f) Create a bar chart suitable for publication that summarizes the average borrowed 
# amount for each income quartile, by treatment group. Save the chart as a PNG file.

# Create income quartiles
merged_clean <- merged_clean %>%
  mutate(income_quartile = ntile(hhinc, 4)) %>%
  mutate(
    income_quartile = factor(
      income_quartile,
      labels = c("Q1 (Lowest)", "Q2", "Q3", "Q4 (Highest)")
    ),
    treated = factor(treated, labels = c("Control", "Treatment"))
  )

# Summarize mean borrowed amount by income quartile and treatment
borrow_summary <- merged_clean %>%
  group_by(treated, income_quartile) %>%
  summarise(mean_borrowed = mean(total_borrowed, na.rm = TRUE), .groups = "drop")

###average borrowing by incquartile----

# Plot with labels
borrow_plot <- ggplot(borrow_summary, aes(x = income_quartile, y = mean_borrowed, fill = treated)) +
  geom_bar(stat = "identity", position = "dodge") +
  geom_text(aes(label = round(mean_borrowed, 0)), 
            position = position_dodge(width = 0.9), 
            vjust = -0.5, size = 3.5) +  # Adjust text size and vertical position
  labs(
    title = "Average Borrowed Amount by Income Quartile and Treatment Group",
    x = "Income Quartile",
    y = "Average Borrowed Amount (RWF)",
    fill = "Group"
  ) +  
  theme_minimal() +
  theme(
    panel.background = element_rect(fill = "white", color = NA),
    plot.background = element_rect(fill = "white", color = NA)
  )


# Save the plot
# Save the plot to the output folder
ggsave(
  filename = here("output", "average_borrowed_by_incquartile.png"),
  plot = borrow_plot,
  width = 8,
  height = 6,
