# b) Choose a few baseline household variables, and perform t-tests or produce a balance table to -----

# Reproducing a balance table similar to Stata's `iebaltab`
#
# The goal is to present:
#   - Group means with standard deviations in parentheses
#   - Differences in means with standard errors clustered at the group_id level
#   - Sample sizes for treated and control groups
#   - Number of clusters per group and in total
#
# Initially, I intended to include only significance stars to indicate differences,
# but since two variables show significant differences, I included the actual p-values
# to better assess how small they are and how concerned we should be.
#
# Because I require flexibility in clustering (e.g., at the group_id level),
# I used a regression-based difference-in-means test with cluster-robust standard errors.
# This approach is statistically equivalent to a t-test under certain assumptions,
# but allows for more robust inference in clustered randomized designs.
#
#I did consult chatGPT to achieve the best version of code to give me my intended result.
#



# Define variables
vars <- c("hhnomembers_baseline", "gender_hoh", "age_hoh", 
          "educyears_hoh", "readwrite_hoh", "hhcaste_sc_st")


#Balance results
balance_results <- lapply(vars, function(var) {
  # Formula
  formula <- as.formula(paste(var, "~ treated"))
  
  # OLS with cluster-robust SEs
  model <- lm(formula, data = merged_clean)
  vcov_clustered <- vcovCR(model, cluster = merged_clean$group_id, type = "CR2")
  est <- tidy(model, vcov = vcov_clustered) %>% filter(term == "treated")
  
  # Means, SDs, and Ns
  stats <- merged_clean %>%
    group_by(treated) %>%
    summarise(
      mean = mean(.data[[var]], na.rm = TRUE),
      sd = sd(.data[[var]], na.rm = TRUE),
      n = sum(!is.na(.data[[var]])),
      .groups = "drop"
    ) %>%
    pivot_wider(
      names_from = treated,
      values_from = c(mean, sd, n),
      names_glue = "{.value}_{treated}"
    )
  
  # Significance stars
  stars <- case_when(
    est$p.value < 0.01 ~ "***",
    est$p.value < 0.05 ~ "**",
    est$p.value < 0.10 ~ "*",
    TRUE ~ ""
  )
  
  # Cluster counts
  clusters_total <- merged_clean %>% pull(group_id) %>% n_distinct()
  clusters_treated <- merged_clean %>% filter(treated == 1) %>% pull(group_id) %>% n_distinct()
  clusters_control <- merged_clean %>% filter(treated == 0) %>% pull(group_id) %>% n_distinct()
  
  tibble(
    variable = var,
    `mean_control(sd)` = sprintf("%.2f (%.2f)", stats$mean_0, stats$sd_0),
    `mean_treated(sd)` = sprintf("%.2f (%.2f)", stats$mean_1, stats$sd_1),
    `diff(se)` = sprintf("%.2f (%.2f)%s", est$estimate, est$std.error, stars),
    p_value = round(est$p.value, 3),
    N_control = stats$n_0,
    N_treated = stats$n_1,
    clusters_control = clusters_control,
    clusters_treated = clusters_treated,
    clusters_total = clusters_total
  )
}) %>% bind_rows()


