# c) Regress (with OLS) the household income on the treatment dummy. Include pair fixed ----
# effects, and correct standard errors if necessary.\


reg_income <- felm(hhinc ~ treated | pair_id | 0 | group_id, data = merged_clean)

summary(reg_income)



# d) Generate a log income variable, and re-run the previous specification with log household ----
# income as the dependent variable.

merged_clean <- merged_clean %>%
  mutate(log_hhinc = ifelse(hhinc > 0, log(hhinc), NA))

reg_log_income <- felm(log_hhinc ~ treated | pair_id | 0 | group_id, data = merged_clean)

summary(reg_log_income)

#create latex to be included in overleaf/latex

###regression output----
stargazer(
  reg_income,
  reg_log_income,
  type = "latex",
  title = "Regression Results No Control",
  out = here("output", "no_controlled_regression.tex")
  
)

#save html
stargazer(
  reg_income,
  reg_log_income,
  type = "html",
