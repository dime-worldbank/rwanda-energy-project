#Figures 4–5: Interest rate distribution (credit market)----

sum(is.na(df_credit$loan_rate))


credit_rates <- df_credit %>%
  mutate(
    rate_round = round(loan_rate, 0),
    rate_bin = case_when(
      rate_round <= 10 ~ "0-10",
      rate_round <= 20 ~ "11-20",
      rate_round <= 30 ~ "21-30",
      rate_round <= 40 ~ "31-40",
      rate_round <= 50 ~ "41-50",
      TRUE ~ "Above 50"
    )
  ) %>%
  mutate(
    rate_bin = factor(
      rate_bin,
      levels = c("0-10","11-20","21-30","31-40","41-50","Above 50")
    ),
    loan_type = factor(loan_type, levels = c("Term Loan", "Line of Credit"))
  )


sum_credit <- credit_rates %>% 
  group_by(rate_bin, loan_type) %>% 
  summarise(
    num_loans = n(),
    total_borrowed = sum(loan_borrowed, na.rm = TRUE)
  ) %>%
  ungroup()

