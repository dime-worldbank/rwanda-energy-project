#Figure 6: Rolling Outstanding Payables vs. Receivables (Firm 3)----

firm3_invoices <- df_invoices %>%
  filter(id_seller == 3 | id_buyer == 3)

invoice_panel <- tidyr::crossing(date = dates_2023, firm3_invoices ) #AI assisted because I never used this function

# Outstanding AR

ar_outstanding <- invoice_panel %>%
  filter(id_seller == 3) %>%
  select(date, issue_date, due_date, payment) %>%
  filter(issue_date <= date, due_date > date) %>%
  group_by(date) %>%
  summarise(
    outstanding_ar = sum(payment, na.rm = TRUE)
  )


# Outstanding AP
ap_outstanding <- invoice_panel %>%
  filter(id_buyer == 3) %>% 
  select(date, issue_date, due_date, payment) %>%
  filter(issue_date <= date, due_date > date) %>%
  group_by(date) %>%
  summarise(
    outstanding_ap = sum(payment, na.rm = TRUE)
  ) %>% 
  right_join(data.frame(date = dates_2023), by = "date") %>%
  mutate(outstanding_ap = replace_na(outstanding_ap, 0)) %>% 
  arrange(date)

outstanding_join <- ar_outstanding %>% 
  left_join(ap_outstanding, by = c("date") )

##plot---- 
#AI assisted

