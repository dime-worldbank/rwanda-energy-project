p_ntl <- ggplot(district_ntl_2014) +
geom_sf(aes(fill = value_adj), color = NA) +
scale_fill_gradient(
low = "black",
high = "yellow"
) +
theme_void() +
theme(legend.position = "none")
ggsave(
filename = file.path(
historical_data_path,
"Nightlight",
"output",
paste0(dist_name, "_Nightlight_2014.png")
),
