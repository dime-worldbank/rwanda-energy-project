)
rwa_village_sp <- st_transform(rwa_village, crs = st_crs(ntl_2014_01))
# ---- 4. Mask entire stack ----
viirs_masked <- mask(viirs_stack, rwa_village_sp)
# ---- 5. Create monthly names (YYYY-MM) ----
n_layers <- nlayers(viirs_masked)
month_seq <- seq(
